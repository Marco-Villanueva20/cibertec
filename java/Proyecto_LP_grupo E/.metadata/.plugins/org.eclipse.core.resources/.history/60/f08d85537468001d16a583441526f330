	}
	

	private double getPrecio() {
		double pre = -1;
		// campo vacío
		if (txtPrecio.getText().trim().length() == 0) {
			Alertas.mensajeError("Ingresar el precio del producto");
			txtPrecio.setText("");
			txtPrecio.requestFocus();
		} else if(txtPrecio.getText().trim().matches(Validaciones.PRECIO_PRODUCTO)){
			pre = txtPrecio.getText().trim().length();
		}else {
			Alertas.mensajeError("Formato incorrecto, ingresar el precio en formato con 2 decimales");
			txtPrecio.setText("");
			txtPrecio.requestFocus();
		}
		return pre;
	}

	private int getStock() {
		int stock = -1;
		// campo vacío
		if (txtPassword.getText().trim().length() == 0) {
			Alertas.mensajeError("Ingresar la cantidad del producto");
			txtPassword.setText("");
			txtPassword.requestFocus();
		} else if (txtPassword.getText().trim().matches(Validaciones.CANTIDAD_PRODUCTO)) {
			stock = txtPassword.getText().trim().length();
		}else {
			Alertas.mensajeError("Formato incorrecto, ingresar solo valores numericos");
			txtPassword.setText("");
			txtPassword.requestFocus();
		}
			return stock;
	}

	private String getNombre() {
		String nomb = null;
		if(txtNombreUsuario.getText().length() == 0 ) {
