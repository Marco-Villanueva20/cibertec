		for(int i = 0; i < cboTipoUsuario.getItemCount(); i ++){
			item = (TipoUsuario) cboTipoUsuario.getItemAt(i);
			if(item.getCodigo() == tUsuario.getCodigo()){
				cboTipoUsuario.setSelectedIndex(i);
				break;
			}
		}
	}
	
	void cargarEstadosCombo(Estados estados){
