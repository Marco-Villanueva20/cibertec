	}
	
	
	void cargarCategoriaCombo(CategoriaProducto categoria){
		CategoriaProducto item;
		for(int i = 0; i < cboTipoUsuario.getItemCount(); i ++){
			item = (CategoriaProducto) cboTipoUsuario.getItemAt(i);
			if(item.getCodigo() == categoria.getCodigo()){
				cboTipoUsuario.setSelectedIndex(i);
				break;
			}
		}
	}

		
