	private void cargarDataComboBoxCategoria() {
		//Paso 1: Obtener el resultado del proceso -- listar
		ArrayList<CategoriaProducto> list = gCat.listar();
		
		//Paso 2: Validar el resultado del proceso
		if(list.size() == 0) {
			Alertas.mensajeError("Lista vacía");
		}else {
			cboCategoria.addItem("Seleccione...");
			for ( CategoriaProducto tipoProducto : list) {
				cboCategoria.addItem(tipoProducto.getCodigo()+"- "+tipoProducto.getDescripcion());
			}
		}
		
	}
	
	private void cargarDataComboBoxProveedor() {
